{
    "ID": "SettingsLightCache",
    "Parameters": [
        {
            "attr": "file",
            "subtype": "VRAY_FILE_PATH"
        },
        {
            "attr": "file_selector",
            "type": "TEMPLATE",
            "options": {
                "template": {
                    "type": "templateFileSelect",
                    "args": {
                        "bound_property": "file",
                        "object_type": "settings"
                    }
                }
            },
            "ui": {
                "display_name": "Light Cache File"
            }
        },
        {
            "attr": "auto_save_file",
            "default": "//auto_save_cache.vrlmap",
            "subtype": "VRAY_FILE_PATH"
        },
        {
            "attr": "auto_save_file_selector",
            "type": "TEMPLATE",
            "options": {
                "template": {
                    "type": "templateFileSelect",
                    "args": {
                        "bound_property": "auto_save_file",
                        "object_type": "settings"
                    }
                }
            },
            "ui": {
                "display_name": "Auto Save File"
            }
        },
        {
            "attr" : "auto_save",
            "default" : false
        },
        {
            "attr": "subdivs",
            "default": 1000
        },
        {
            "attr": "num_passes_auto",
            "default": true,
            "desc": "Set number of passes to threads number",
            "name": "Auto Num. Passes",
            "type": "BOOL",
            "options": {
                "derived": true
            }
        },
        {
            "attr": "filter",
            "default": true,
            "desc": "",
            "name": "Filter",
            "type": "BOOL",
            "options": {
                "derived": true
            }
        },
        {
            "attr": "use_for_glossy_rays",
            "default": true,
            "desc": "True if the light cache should be used to estimate GI for glossy rays, instead of the primary GI engine",
            "type": "BOOL",
            "ui": {
                "display_name": "Use for glossy rays"
            }
        },
        {
            "attr": "premultiplied",
            "default": true,
            "desc": "true to use premultiplied light cache when possible",
            "type": "BOOL",
            "ui": {
                "display_name": "Premultiplied"
            }
        },
        {
            "attr": "mode",
            "default": "0",
            "desc": "Specifies the way the light cache is calculated (Single Frame, From File)",
            "items": [
                [
                    "0",
                    "Single Frame",
                    "Single Frame"
                ],
                [
                    "2",
                    "From File",
                    "From File"
                ]
            ],
            "type": "ENUM",
            "ui": {
                "display_name": "Mode"
            }
        },
        {
            "attr": "retrace_enabled",
            "default": true,
            "ui": {
                "display_name": "Use Retrace Threshold"
            }
        },
        {
            "attr": "retrace_threshold",
            "default": 2.0
        },
        {
            "attr": "sample_size",
            "ui": {
                "display_name": "Sample Size",
                "max": 1000000000.0,
                "min": 0.0
            }
        }
    ],
    "Widget": {
        "widgets": [
            {
                "layout": "COLUMN",
                "attrs": [
                    {
                        "name": "mode"
                    },
                    {
                        "layout": "SEPARATOR"
                    },
                    {
                        "layout": "COLUMN",
                        "visible": {"cond": "::mode!=2"},
                        "attrs": [
                            {
                                "name": "subdivs"
                            },
                            {
                                "name": "sample_size"
                            },
                            {
                                "layout": "SEPARATOR"
                            }
                        ]
                    },
                    {
                        "name": "retrace_enabled"
                    },
                    {
                        "name": "retrace_threshold",
                        "active": {"cond": "::retrace_enabled!=0"}
                    },
                    {
                        "name": "path_guiding",
                        "label": "Path Guiding (Experimantal)"
                    },
                    {
                        "layout": "COLUMN",
                        "visible": {"cond": "::mode!=2"},
                        "attrs": [
                            {
                                "name": "auto_save"
                            },
                            {
                                "name": "auto_save_file_selector",
                                "active": {"cond": "::auto_save!=0"}
                            }
                        ]
                    },
                    {
                        "name": "file_selector",
                        "visible": {"cond": "::mode=2"}
                    }

                ]
            }
        ]
    },
    "Options": {
        "excluded_parameters": [
            "filter_type",
            "filter_samples",
            "filter_size",
            "prefilter",
            "prefilter_samples"
        ],
        "animatable": false
    }
}